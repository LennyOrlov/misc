# Google core (needed for many services above)
DOMAIN-SUFFIX,googleapis.com,PROXY
DOMAIN-SUFFIX,gstatic.com,PROXY
DOMAIN-SUFFIX,googleusercontent.com,PROXY

# Voice call ports (Telegram, WhatsApp, FaceTime)
AND,((PROTOCOL,UDP),(DEST-PORT,3478)),PROXY
AND,((PROTOCOL,UDP),(DEST-PORT,4244)),PROXY
AND,((PROTOCOL,UDP),(DEST-PORT,5222)),PROXY
AND,((PROTOCOL,UDP),(DEST-PORT,5223)),PROXY
AND,((PROTOCOL,UDP),(DEST-PORT,5228)),PROXY
AND,((PROTOCOL,UDP),(DEST-PORT,5242)),PROXY
AND,((PROTOCOL,UDP),(DEST-PORT,45395)),PROXY
AND,((PROTOCOL,UDP),(DEST-PORT,50318)),PROXY
AND,((PROTOCOL,UDP),(DEST-PORT,59234)),PROXY

# =============================================
# DEFAULT: Everything else goes DIRECT
# =============================================
FINAL,DIRECT

[Host]
localhost = 127.0.0.1
