DOMAIN-SUFFIX,fb.com,PROXY
DOMAIN-SUFFIX,fb.me,PROXY
DOMAIN-SUFFIX,fbcdn.net,PROXY
DOMAIN-SUFFIX,fbsbx.com,PROXY
DOMAIN-SUFFIX,fburl.com,PROXY
DOMAIN-SUFFIX,cdnfacebook.com,PROXY
DOMAIN-SUFFIX,cdnfbsbx.com,PROXY
DOMAIN-SUFFIX,meta.com,PROXY
DOMAIN-SUFFIX,threads.net,PROXY
IP-CIDR,31.13.24.0/21,PROXY,no-resolve
IP-CIDR,31.13.64.0/18,PROXY,no-resolve
